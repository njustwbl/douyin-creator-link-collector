APP_NAME=CareerAgent Collector
APP_ENV=development
DATABASE_URL=sqlite+aiosqlite:///./data/career_agent.db

# 默认使用可见浏览器。首次运行遇到登录或验证码时，可以人工处理。
DOUYIN_HEADLESS=false
DOUYIN_BROWSER_PROFILE_DIR=./data/browser/douyin
DOUYIN_PAGE_TIMEOUT_SECONDS=60
DOUYIN_VERIFICATION_TIMEOUT_SECONDS=300
DOUYIN_MAX_SCROLLS=120
DOUYIN_IDLE_ROUNDS=8
DOUYIN_SCROLL_WAIT_MS=1200

# 原始响应体可能很大，MVP 默认不入库。调试时可以打开。
STORE_RAW_PAYLOAD=false

# 浏览器兜底滚动参数。v0.2.4 不再逐条打开详情页；旧详情参数仅保留兼容。
DOUYIN_RETRY_SCROLL_ROUNDS=6
DOUYIN_DETAIL_TIMEOUT_SECONDS=12
DOUYIN_DETAIL_CONCURRENCY=3
DOUYIN_DETAIL_BUFFER=4

# v0.2.4：极速分页接口。默认开启；接口失败时仅打开博主主页做浏览器兜底，
# 不会逐条打开作品详情页。
DOUYIN_SESSION_SNAPSHOT_PATH=./data/browser/douyin_session.json
DOUYIN_FAST_API_TIMEOUT_SECONDS=12
DOUYIN_ENABLE_BROWSER_FALLBACK=true

# 极速接口失败时使用指数退避重试，避免短暂网络抖动直接触发浏览器兜底。
DOUYIN_FAST_RETRY_ATTEMPTS=3
DOUYIN_FAST_RETRY_BASE_DELAY_MS=350

# 结构化日志按大小轮转；日志不保存 Cookie 和签名参数。
LOG_DIR=./data/logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
