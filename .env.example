# CareerAgent advanced configuration example.
# Normal Windows users can configure storage and local models in the Web UI.

APP_NAME=CareerAgent
APP_ENV=development

# Optional fixed locations for unattended or advanced deployments.
# CAREER_AGENT_HOME=D:/CareerAgentData
# CAREER_AGENT_EXPORT_DIR=D:/CareerAgentExports
# DATABASE_URL=sqlite+aiosqlite:///D:/CareerAgentData/database/career_agent.db

# -----------------------------------------------------------------------------
# Douyin collection
# -----------------------------------------------------------------------------
DOUYIN_HEADLESS=false
# DOUYIN_BROWSER_PROFILE_DIR=D:/CareerAgentData/browser/douyin
# DOUYIN_SESSION_SNAPSHOT_PATH=D:/CareerAgentData/browser/douyin_session.json
DOUYIN_PAGE_TIMEOUT_SECONDS=60
DOUYIN_VERIFICATION_TIMEOUT_SECONDS=300
DOUYIN_MAX_SCROLLS=120
DOUYIN_IDLE_ROUNDS=8
DOUYIN_SCROLL_WAIT_MS=1200
DOUYIN_RETRY_SCROLL_ROUNDS=6
DOUYIN_DETAIL_TIMEOUT_SECONDS=12
DOUYIN_DETAIL_CONCURRENCY=3
DOUYIN_DETAIL_BUFFER=4
DOUYIN_FAST_API_TIMEOUT_SECONDS=12
DOUYIN_FAST_RETRY_ATTEMPTS=3
DOUYIN_FAST_RETRY_BASE_DELAY_MS=350
DOUYIN_ENABLE_BROWSER_FALLBACK=true
STORE_RAW_PAYLOAD=false

# Multi-creator calendar-day collection.
DOUYIN_BATCH_MAX_PAGES=50
DOUYIN_BATCH_ENABLE_BROWSER_FALLBACK=false
DOUYIN_BATCH_CONCURRENCY=4
DOUYIN_BATCH_RESOLVE_CONCURRENCY=12
DOUYIN_BATCH_TIMEOUT_SECONDS=8
DOUYIN_BATCH_RETRY_ATTEMPTS=2
DOUYIN_BATCH_RETRY_BASE_DELAY_MS=180
DOUYIN_BATCH_FETCH_PROFILE_DETAILS=false

# -----------------------------------------------------------------------------
# Structured logs and diagnostics
# -----------------------------------------------------------------------------
# LOG_DIR=D:/CareerAgentData/logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
DIAGNOSTICS_INCLUDE_TECHNICAL_DETAIL=true

# -----------------------------------------------------------------------------
# Transcription, OCR, article extraction, and media cache
# -----------------------------------------------------------------------------
# TRANSCRIPTION_MEDIA_DIR=D:/CareerAgentData/cache/media
# TRANSCRIPTION_EXPORT_DIR=D:/CareerAgentExports
# ASR_MODEL_CACHE_DIR=D:/CareerAgentData/models
TRANSCRIPTION_RESOLVE_TIMEOUT_SECONDS=20
TRANSCRIPTION_DOWNLOAD_CONNECT_TIMEOUT_SECONDS=20
TRANSCRIPTION_DOWNLOAD_TIMEOUT_SECONDS=600
TRANSCRIPTION_FFMPEG_TIMEOUT_SECONDS=600
TRANSCRIPTION_KEEP_MEDIA=false
TRANSCRIPTION_KEEP_FAILED_MEDIA=false
TRANSCRIPTION_CACHE_TTL_HOURS=24
TRANSCRIPTION_CLEANUP_ON_STARTUP=true
TRANSCRIPTION_MEDIA_CACHE_MAX_BYTES=2147483648
TRANSCRIPTION_MAX_MEDIA_BYTES=2147483648
TRANSCRIPTION_MAX_IMAGE_BYTES=52428800

# Shared AI-domain hotwords.
ASR_HOTWORDS=Agent RAG Token Prompt Embedding LangGraph MCP Claude Code Codex Workflow Trace Skill Context DeepSeek FastAPI Whisper SenseVoice Paraformer PyTorch CUDA cuDNN CTranslate2 FDE

# SenseVoiceSmall / FunASR.
SENSEVOICE_MODEL_NAME=iic/SenseVoiceSmall
SENSEVOICE_VAD_MODEL=fsmn-vad
SENSEVOICE_DEVICE=auto
SENSEVOICE_MAX_SEGMENT_MS=30000
SENSEVOICE_BATCH_SIZE_SECONDS=300
SENSEVOICE_MERGE_LENGTH_SECONDS=15

# Paraformer / FunASR.
PARAFORMER_MODEL_NAME=paraformer-zh
PARAFORMER_VAD_MODEL=fsmn-vad
PARAFORMER_PUNC_MODEL=ct-punc
PARAFORMER_DEVICE=auto
PARAFORMER_MAX_SEGMENT_MS=60000
PARAFORMER_BATCH_SIZE_SECONDS=300
PARAFORMER_MERGE_LENGTH_SECONDS=15

# faster-whisper.
WHISPER_MODEL_NAME=medium
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE_CPU=int8
WHISPER_COMPUTE_TYPE_CUDA=float16
WHISPER_LANGUAGE=zh
WHISPER_BEAM_SIZE=5
WHISPER_MIN_SILENCE_MS=700
WHISPER_SPEECH_PAD_MS=300
WHISPER_MAX_SPEECH_SECONDS=28
WHISPER_HALLUCINATION_SILENCE_SECONDS=2.0
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
WHISPER_CPU_THREADS=0

# OCR and article extraction.
OCR_MIN_IMAGE_BYTES=1024
OCR_MAX_IMAGE_BYTES=52428800
ARTICLE_MAX_CHARS=500000

# Background transcription batches.
TRANSCRIPTION_BATCH_CONCURRENCY=8
TRANSCRIPTION_BATCH_MAX_ITEMS=100
TRANSCRIPTION_BATCH_POLL_INTERVAL_MS=1000

# -----------------------------------------------------------------------------
# Compute runtime
# -----------------------------------------------------------------------------
# auto: use CUDA when an NVIDIA GPU is available; otherwise use CPU.
# cpu: force CPU. cuda: require a CUDA-capable runtime.
CAREERAGENT_ACCELERATOR=auto
CAREERAGENT_ALLOW_CPU_FALLBACK=true
PYTORCH_CUDA_INDEX_URL=https://download.pytorch.org/whl/cu128
PYTORCH_CPU_INDEX_URL=https://download.pytorch.org/whl/cpu

# Ollama chat/embedding settings are normally saved from the Web UI under the
# CareerAgent data directory. Defaults:
#   Base URL: http://127.0.0.1:11434
#   Chat model: qwen3.5:4b
#   Embedding model: qwen3-embedding:4b
